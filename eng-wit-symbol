%{
#include <stdio.h>
#include <string.h>

struct sym {
    char name[50];
    char type[30];
} table[100];
int cnt = 0;

void insert(char *name, char *type){
    int i;
    for(i=0; i<cnt; i++)
        if(strcmp(table[i].name, name)==0) return;
    strcpy(table[cnt].name, name);
    strcpy(table[cnt].type, type);
    cnt++;
}

void display(){
    int i;
    printf("\n====== SYMBOL TABLE ======\n");
    printf("%-15s %-15s\n", "Word", "Type");
    printf("--------------------------\n");
    for(i=0; i<cnt; i++)
        printf("%-15s %-15s\n", table[i].name, table[i].type);
    printf("==========================\n");
}
%}
%%
"car"|"house"|"man"|"city"|"ocean"      { printf("%s = NOUN\n",        yytext); insert(yytext,"NOUN"); }
"he"|"she"|"we"|"they"|"it"            { printf("%s = PRONOUN\n",     yytext); insert(yytext,"PRONOUN"); }
"go"|"come"|"walk"|"read"|"write"      { printf("%s = VERB\n",        yytext); insert(yytext,"VERB"); }
"pretty"|"old"|"blue"|"smart"          { printf("%s = ADJECTIVE\n",   yytext); insert(yytext,"ADJECTIVE"); }
"actually"|"calmly"|"brightly"         { printf("%s = ADVERB\n",      yytext); insert(yytext,"ADVERB"); }
"by"|"with"|"about"|"until"            { printf("%s = PREPOSITION\n", yytext); insert(yytext,"PREPOSITION"); }
"and"|"but"|"or"|"while"|"because"     { printf("%s = CONJUNCTION\n", yytext); insert(yytext,"CONJUNCTION"); }
"Oh!"|"Wow!"|"Oops!"                   { printf("%s = INTERJECTION\n",yytext); insert(yytext,"INTERJECTION"); }
[a-zA-Z!]+                             { printf("%s = UNKNOWN\n",     yytext); insert(yytext,"UNKNOWN"); }
[ \t\n]                                { ; }
%%
int yywrap(){ return 1; }
int main(){
    printf("Enter sentence (Ctrl+D to stop):\n");
    yylex();
    display();
    return 0;
}