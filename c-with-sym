%{
#include <stdio.h>
#include <string.h>
struct sym {
    char name[50];
    char type[30];
} table[200];
int cnt = 0;
void insert(char *name, char *type){
    int i;
    for(i=0; i<cnt; i++)
        if(strcmp(table[i].name, name)==0) return;
    strcpy(table[cnt].name, name);
    strcpy(table[cnt].type, type);
    cnt++;
}
void display(){
    int i;
    printf("\n====== SYMBOL TABLE ======\n");
    printf("%-15s %-15s\n", "Token", "Type");
    printf("--------------------------\n");
    for(i=0; i<cnt; i++)
        printf("%-15s %-15s\n", table[i].name, table[i].type);
    printf("==========================\n");
}
%}
%%
"int"|"float"|"char"|"void"|"if"|"else"|"while"|"for"|"return"|"printf"|"scanf" { printf("%-10s = KEYWORD\n", yytext); insert(yytext,"KEYWORD"); }
"%d"|"%c"|"%f"|"%s"         { printf("%-10s = FORMAT SPEC\n",    yytext); insert(yytext,"FORMAT SPEC"); }
[0-9]+\.[0-9]+              { printf("%-10s = FLOAT\n",          yytext); insert(yytext,"FLOAT"); }
[0-9]+                      { printf("%-10s = INTEGER\n",        yytext); insert(yytext,"INTEGER"); }
[a-zA-Z_][a-zA-Z0-9_]*      { printf("%-10s = IDENTIFIER\n",    yytext); insert(yytext,"IDENTIFIER"); }
"&&"                        { printf("%-10s = LOGICAL AND\n",    yytext); insert(yytext,"LOGICAL AND"); }
"||"                        { printf("%-10s = LOGICAL OR\n",     yytext); insert(yytext,"LOGICAL OR"); }
"!="|"+="|"-="|"*="|"/="   { printf("%-10s = COMPOUND OP\n",    yytext); insert(yytext,"COMPOUND OP"); }
"<="|">="|"=="              { printf("%-10s = RELATIONAL OP\n",  yytext); insert(yytext,"RELATIONAL"); }
[<>]                        { printf("%-10s = RELATIONAL OP\n",  yytext); insert(yytext,"RELATIONAL"); }
"="                         { printf("%-10s = ASSIGNMENT OP\n",  yytext); insert(yytext,"ASSIGNMENT"); }
"+"|"-"|"*"|"/"             { printf("%-10s = ARITH OP\n",       yytext); insert(yytext,"ARITH OP"); }
"{"|"}"|"("|")"|";"|"#"    { printf("%-10s = PUNCTUATION\n",    yytext); insert(yytext,"PUNCTUATION"); }
[ \t\n]                     { ; }
.                           { printf("%-10s = UNKNOWN\n",        yytext); }
%%
int yywrap(){ return 1; }
int main(){
    printf("Enter C code (Ctrl+D to stop):\n");
    yylex();
    display();
    return 0;
}