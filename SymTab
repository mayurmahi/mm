print()
print("=" * 60)
print("SYMBOL TABLE")
print("=" * 60)

print("SYMBOL\tADDRESS\tLENGTH")

for sym in SYMTAB:

    address = SYMTAB[sym][0]
    length = SYMTAB[sym][1]

    print(sym, "\t", address, "\t", length)

