# OUTPUT : LITERAL TABLE
# ============================================================

print()
print("=" * 60)
print("LITERAL TABLE")
print("=" * 60)

print("INDEX\tLITERAL\tADDRESS")

for i in range(len(LITTAB)):

    print(i, "\t", LITTAB[i][0], "\t", LITTAB[i][1])

# ============================================================
# OUTPUT : POOL TABLE
# ============================================================

print()
print("=" * 60)
print("POOL TABLE")
print("=" * 60)

print("POOL#\tSTART")

for i in range(len(POOLTAB)):

    print(i + 1, "\t", POOLTAB[i])

print()
