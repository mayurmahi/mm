# ============================================================
# FUNCTION : EVALUATE EXPRESSIONS
# Handles:
# 120
# A
# A+2
# LOOP-1
# ============================================================

def evaluate_expression(expr):

    # A+2
    if "+" in expr:

        sym, offset = expr.split("+")

        return SYMTAB[sym][0] + int(offset)

    # A-2
    elif "-" in expr:

        sym, offset = expr.split("-")

        return SYMTAB[sym][0] - int(offset)

    # Only Symbol
    elif expr in SYMTAB:

        return SYMTAB[expr][0]

    # Constant
    else:

        return int(expr)

